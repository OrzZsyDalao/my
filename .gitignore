__pycache__/
*.py[cod]

# Runtime-only isolated experiment products. Keep structure/documentation in
# version control, but do not commit raw trace-derived runs or paper bundles.
runs/*
!runs/.gitkeep
paper_results/*
!paper_results/.gitkeep
.pytest_cache/
*.pyc

data/**
!data/
!data/asrelationship/
!data/asrelationship/.gitkeep
!data/cable/
!data/cable/.gitkeep
!data/ipinfo/
!data/ipinfo/.gitkeep
!data/owner2asn/
!data/owner2asn/.gitkeep
!data/pfx2as/
!data/pfx2as/.gitkeep
!data/probe/
!data/probe/.gitkeep
!data/traceroute/
!data/traceroute/.gitkeep
!data/traceroute_rundnsroot/
!data/traceroute_rundnsroot/.gitkeep

output/result/**
!output/result/
!output/result/.gitkeep
output/result_5051/cable_matching_output.json
output/result_5051/trace_candidate_support.csv
output/result_5051/trace_feasible_candidate_space.csv
output/preprocessed/**
!output/preprocessed/
!output/preprocessed/.gitkeep

cable_loading_debug.json

probe/atlas_traceroute_config.json
probe/atlas_traceroute_config.local.json
